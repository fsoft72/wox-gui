{
  "name": "wox-gui",
  "version": "0.1.9",
  "description": "WOX — Web Component UI library",
  "type": "module",
  "main": "./dist/wox-gui.js",
  "module": "./dist/wox-gui.js",
  "sideEffects": [
    "./dist/register.js",
    "./dist/wox-gui.cdn.js"
  ],
  "exports": {
    ".": "./dist/wox-gui.js",
    "./register": "./dist/register.js",
    "./cdn": "./dist/wox-gui.cdn.js",
    "./theme": "./dist/wox-theme.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.config.cdn.js && cp css/wox-theme.css dist/wox-theme.css",
    "build:site": "pnpm build && bash scripts/build-site.sh",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "vite": "^6.2.0"
  },
  "keywords": [
    "web-components",
    "ui",
    "component-library",
    "custom-elements"
  ],
  "license": "MIT"
}
